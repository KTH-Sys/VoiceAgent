# Copy to .env.local and fill in real values. Never commit .env.local.

# Vocal Bridge (vocalbridgeai.com/app — API keys)
VOCALBRIDGE_API_KEY=
VOCALBRIDGE_AGENT_ID=
# Only set if the developer guide shows a different outbound-call endpoint (default /api/v1/calls)
# VOCALBRIDGE_OUTBOUND_PATH=

# Sabre developer hub (developer.sabre.com — test environment)
SABRE_CLIENT_ID=
SABRE_CLIENT_SECRET=
SABRE_BASE_URL=https://api.cert.platform.sabre.com
# Pseudo City Code from your Sabre dev-hub app (leave empty if your key doesn't require one)
SABRE_PCC=

# PayPal sandbox (developer.paypal.com/dashboard)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com

# LandingAI Agentic Document Extraction (ade.landing.ai)
LANDINGAI_API_KEY=

# OpenAI — the brain behind the voice agent (/api/agent)
OPENAI_API_KEY=
# Optional model override (default gpt-4o)
# OPENAI_MODEL=

# Demo: phone number the disruption call goes to (E.164, e.g. +14155551234)
DEMO_USER_PHONE=
